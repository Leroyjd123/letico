{
  "extends": "@lectio/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lectio/types": ["../../packages/types/src/index.ts"],
      "@lectio/types/tokens": ["../../packages/types/src/tokens.ts"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
