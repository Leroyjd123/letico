{
  "name": "@lectio/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@lectio/types": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "@supabase/ssr": "^0.6.1",
    "@tanstack/react-query": "^5.67.2",
    "idb": "^8.0.2",
    "next": "^14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@lectio/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@lectio/types$": "<rootDir>/../../packages/types/src/index.ts",
      "^@lectio/types/tokens$": "<rootDir>/../../packages/types/src/tokens.ts"
    },
    "setupFilesAfterEnv": ["@testing-library/jest-dom"],
    "testMatch": ["**/__tests__/**/*.test.(ts|tsx)"]
  }
}
