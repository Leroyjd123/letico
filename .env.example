# Supabase — project URL (from Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase — service role key (secret — never expose in frontend)
# Found in Supabase dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — anon/public key (safe to expose in frontend via NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API base URL — where the NestJS API is reachable from the Next.js app
# Local: http://localhost:4000/api | Production: https://api.lectio.app/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# NestJS server port
PORT=4000

# CORS — frontend origin(s) allowed to call the API (comma-separated)
FRONTEND_URL=http://localhost:3000
